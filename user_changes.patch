new file mode 100644
index 0000000..308c10a
--- /dev/null
+++ b/features.css
@@ -0,0 +1,303 @@
+/* --- Elite Features Enhancements --- */
+
+.features-bento-grid {
+    display: grid;
+    grid-template-columns: repeat(12, 1fr);
+    grid-auto-rows: minmax(200px, auto);
+    gap: 24px;
+    margin: 60px 0;
+}
+
+.bento-card {
+    background: rgba(255, 255, 255, 0.7);
+    backdrop-filter: blur(20px);
+    -webkit-backdrop-filter: blur(20px);
+    border: 1px solid rgba(255, 255, 255, 0.4);
+    border-radius: 32px;
+    padding: 40px;
+    position: relative;
+    overflow: hidden;
+    transition: all 0.5s cubic-bezier(0.19, 1, 0.22, 1);
+    box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.05);
+    display: flex;
+    flex-direction: column;
+    text-align: left;
+}
+
+.bento-card:hover {
+    transform: translateY(-8px);
+    box-shadow: 0 40px 80px -20px rgba(10, 80, 255, 0.12);
+    border-color: rgba(10, 80, 255, 0.2);
+}
+
+.bento-card.span-6 {
+    grid-column: span 6;
+}
+
+.bento-card.span-4 {
+    grid-column: span 4;
+}
+
+.bento-card.span-8 {
+    grid-column: span 8;
+}
+
+.bento-card.span-7 {
+    grid-column: span 7;
+}
+
+.bento-card.span-5 {
+    grid-column: span 5;
+}
+
+.bento-card.tall {
+    grid-row: span 2;
+}
+
+.bento-icon {
+    width: 64px;
+    height: 64px;
+    background: linear-gradient(135deg, var(--cta-blue), #60a5fa);
+    border-radius: 18px;
+    display: flex;
+    align-items: center;
+    justify-content: center;
+    font-size: 24px;
+    color: #fff;
+    margin-bottom: 24px;
+    box-shadow: 0 8px 16px -4px rgba(10, 80, 255, 0.3);
+    z-index: 2;
+}
+
+.bento-title {
+    font-size: 1.8rem;
+    font-weight: 800;
+    margin-bottom: 12px;
+    color: #0f172a;
+    letter-spacing: -0.02em;
+    z-index: 2;
+}
+
+.bento-desc {
+    color: #64748b;
+    line-height: 1.6;
+    font-size: 1.05rem;
+    z-index: 2;
+}
+
+.bento-visual-bg {
+    position: absolute;
+    bottom: -30px;
+    right: -30px;
+    width: 250px;
+    height: 250px;
+    opacity: 0.05;
+    z-index: 1;
+    transition: all 0.5s ease;
+    pointer-events: none;
+    display: flex;
+    align-items: flex-end;
+    justify-content: flex-end;
+}
+
+.bento-card:hover .bento-visual-bg {
+    transform: scale(1.2) rotate(10deg);
+    opacity: 0.15;
+}
+
+.feature-tag-new {
+    display: inline-block;
+    padding: 6px 14px;
+    background: rgba(10, 80, 255, 0.08);
+    color: var(--cta-blue);
+    border-radius: 100px;
+    font-size: 0.75rem;
+    font-weight: 700;
+    text-transform: uppercase;
+    letter-spacing: 1px;
+    margin-bottom: 16px;
+    width: fit-content;
+}
+
+/* Elite Glassmorphic Section */
+.elite-section {
+    padding: 140px 0;
+    background: radial-gradient(circle at top left, #f8faff, #ffffff, #f0f7ff);
+    position: relative;
+    z-index: 1;
+}
+
+.section-label {
+    text-align: center;
+    color: var(--cta-blue);
+    font-weight: 800;
+    text-transform: uppercase;
+    letter-spacing: 3px;
+    font-size: 0.85rem;
+    margin-bottom: 15px;
+    display: block;
+}
+
+.section-title-elite {
+    text-align: center;
+    font-size: 3.5rem;
+    font-weight: 900;
+    margin-bottom: 60px;
+    letter-spacing: -0.03em;
+    color: #0f172a;
+    line-height: 1.1;
+}
+
+/* Timeline / Protocol View */
+.protocol-viz {
+    background: #020617;
+    border-radius: 40px;
+    padding: 80px;
+    color: #fff;
+    margin-top: 100px;
+    position: relative;
+    overflow: hidden;
+}
+
+.protocol-viz::before {
+    content: '';
+    position: absolute;
+    top: 0;
+    left: 0;
+    width: 100%;
+    height: 100%;
+    background: radial-gradient(circle at 70% 30%, rgba(0, 102, 255, 0.15), transparent 60%);
+    pointer-events: none;
+}
+
+.protocol-grid {
+    display: grid;
+    grid-template-columns: 1fr 1fr;
+    gap: 80px;
+    align-items: center;
+    text-align: left;
+}
+
+.protocol-content h2 {
+    font-size: 2.8rem;
+    font-weight: 800;
+    margin-bottom: 24px;
+    background: linear-gradient(to right, #fff, rgba(255, 255, 255, 0.6));
+    -webkit-background-clip: text;
+    background-clip: text;
+    -webkit-text-fill-color: transparent;
+}
+
+.p-features-list {
+    display: flex;
+    flex-direction: column;
+    gap: 32px;
+}
+
+.p-feature-item {
+    display: flex;
+    gap: 20px;
+}
+
+.p-icon-box {
+    width: 48px;
+    height: 48px;
+    background: rgba(255, 255, 255, 0.05);
+    border: 1px solid rgba(255, 255, 255, 0.1);
+    border-radius: 12px;
+    display: flex;
+    align-items: center;
+    justify-content: center;
+    font-size: 20px;
+    color: #0066ff;
+}
+
+.p-info-box h4 {
+    font-size: 1.25rem;
+    font-weight: 700;
+    margin-bottom: 6px;
+    color: #fff;
+}
+
+.p-info-box p {
+    color: #94a3b8;
+    line-height: 1.6;
+}
+
+/* Trust Framework Grid */
+.trust-grid {
+    display: grid;
+    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
+    gap: 30px;
+}
+
+.trust-card {
+    background: #fff;
+    padding: 40px;
+    border-radius: 24px;
+    border: 1px solid #e2e8f0;
+    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.02);
+    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
+    cursor: default;
+    display: flex;
+    flex-direction: column;
+}
+
+.trust-card:hover {
+    transform: translateY(-12px);
+    border-color: rgba(0, 102, 255, 0.2);
+    box-shadow: 0 40px 80px rgba(0, 102, 255, 0.08);
+}
+
+.trust-icon {
+    color: #0066ff;
+    font-size: 2rem;
+    margin-bottom: 20px;
+    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
+}
+
+.trust-card:hover .trust-icon {
+    transform: scale(1.2) rotate(8deg);
+    color: #0052cc;
+}
+
+.trust-card h4 {
+    font-size: 1.25rem;
+    font-weight: 800;
+    margin-bottom: 12px;
+    color: #0f172a;
+}
+
+.trust-card p {
+    color: #64748b;
+    font-size: 0.95rem;
+    line-height: 1.6;
+    margin: 0;
+}
+
+@media (max-width: 992px) {
+    .features-bento-grid {
+        grid-template-columns: repeat(1, 1fr);
+    }
+
+    .bento-card.span-6,
+    .bento-card.span-4,
+    .bento-card.span-8,
+    .bento-card.span-7,
+    .bento-card.span-5 {
+        grid-column: span 1;
+    }
+
+    .protocol-grid {
+        grid-template-columns: 1fr;
+        gap: 40px;
+    }
+
+    .section-title-elite {
+        font-size: 2.5rem;
+    }
+
+    .protocol-viz {
+        padding: 40px 20px;
+    }
+}
